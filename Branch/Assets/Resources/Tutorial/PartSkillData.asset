  m_Script: {fileID: 11500000, guid: 1ebfc1867d3921f4d9fbf05c56abfc5e, type: 3}
  m_Name: PartSkillData
  m_EditorClassIdentifier: 
  key: PartSkill
  title: "\uD30C\uCE20 \uC2A4\uD0AC"
  descriptions:
  - "\uD30C\uCE20 \uC2A4\uD0AC\uC740 \uC7A5\uCC29\uD55C \uB4F1\uACFC \uB2E4\uB9AC
    \uD30C\uCE20\uC5D0 \uB0B4\uC7A5\uB41C \uACE0\uC720 \uAE30\uC220\uC744 \uC0AC\uC6A9\uD558\uC5EC
    \uC804\uD22C\uC640 \uAE30\uB3D9\uC744 \uC720\uB9AC\uD558\uAC8C \uC774\uB044\uB294
    \uAE30\uB2A5\uC785\uB2C8\uB2E4.\n\n\uBCC4\uB3C4\uC758 \uC790\uC6D0 \uC5C6\uC774
    \uC7AC\uC0AC\uC6A9 \uB300\uAE30 \uC2DC\uAC04\uB9CC \uC9C0\uB098\uBA74 \uC5B8\uC81C\uB4E0\uC9C0
    \uC0AC\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uAC01 \uD30C\uCE20\uB294
    \uC11C\uB85C \uB2E4\uB978 \uC131\uACA9\uC758 \uC2A4\uD0AC\uC744 \uBCF4\uC720\uD558\uACE0
    \uC788\uC73C\uBBC0\uB85C, \uC790\uC2E0\uC758 \uD50C\uB808\uC774 \uC2A4\uD0C0\uC77C\uC5D0
    \uB9DE\uB294 \uCD5C\uC801\uC758 \uC2A4\uD0AC \uC870\uD569\uC744 \uCC3E\uB294
    \uAC83\uC774 \uC2B9\uB9AC\uC758 \uC5F4\uC1E0\uC785\uB2C8\uB2E4.\n\n\uAE30\uBCF8\uC801\uC73C\uB85C
    \uC9C0\uAE09\uB418\uB294 \uCD08\uAE30 \uB4F1 \uD30C\uCE20\uC5D0\uB294 \uD30C\uCE20
    \uC2A4\uD0AC \uAE30\uB2A5\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
  - "[ \uC870\uC791 \uBC29\uBC95 ]\n- PC\n\uB4F1 \uC2A4\uD0AC: Space Bar\n\uB2E4\uB9AC
    \uC2A4\uD0AC: Shift\n\n- \uBAA8\uBC14\uC77C\n\uB4F1 \uC2A4\uD0AC: \uC6B0\uCE21
    \uB4F1 \uC2A4\uD0AC \uBC84\uD2BC\n\uB2E4\uB9AC \uC2A4\uD0AC: \uC6B0\uCE21 \uB2E4\uB9AC
    \uC2A4\uD0AC \uBC84\uD2BC"
  exampleImage: {fileID: 21300000, guid: b5ab0fd40c8855e43b911a069348362d, type: 3}
