  m_Script: {fileID: 11500000, guid: 1ebfc1867d3921f4d9fbf05c56abfc5e, type: 3}
  m_Name: ChangePartsData
  m_EditorClassIdentifier: 
  key: ChangeParts
  title: "\uD30C\uCE20 \uAD50\uCCB4"
  descriptions:
  - "\uD50C\uB808\uC774\uC5B4\uB294 \uC804\uD669\uC5D0 \uB9DE\uCDB0 \uC2E4\uC2DC\uAC04\uC73C\uB85C
    \uAE30\uCCB4\uC758 \uBD80\uC704\uBCC4 \uD30C\uCE20\uB97C \uAD50\uCCB4\uD558\uAC70\uB098
    \uBBF8\uB9AC \uC124\uC815\uB41C \uC138\uD2B8\uB85C \uBB34\uC7A5\uC744 \uAD50\uCCB4\uD560
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n\uCD08\uAE30 \uC7A5\uBE44\uB97C \uC81C\uC678\uD55C
    \uCD94\uAC00 \uD30C\uCE20\uB294 \uB9F5 \uACF3\uACF3\uC5D0 \uBC30\uCE58\uB41C
    \uD30C\uCE20 \uC0C1\uC790(\uB178\uB780\uC0C9 \uC678\uACFD\uC120)\uACFC \uC0C1\uD638\uC791\uC6A9\uD558\uC5EC
    \uD68D\uB4DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uD68D\uB4DD\uD55C \uD30C\uCE20\uB294
    \uBCC4\uB3C4\uC758 \uC54C\uB9BC \uC5C6\uC774 \uD30C\uCE20 \uAD50\uCCB4 UI\uC5D0
    \uC989\uC2DC \uB4F1\uB85D\uB418\uBBC0\uB85C, \uC5B8\uC81C\uB4E0\uC9C0 \uD574\uB2F9
    \uD30C\uCE20\uB85C \uAD50\uCCB4\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n\uD30C\uCE20
    \uAD50\uCCB4 UI\uAC00 \uC5F4\uB824 \uC788\uB294 \uB3D9\uC548 \uAC8C\uC784 \uB0B4
    \uC2DC\uAC04\uC774 \uB9E4\uC6B0 \uB290\uB9AC\uAC8C \uD750\uB985\uB2C8\uB2E4.
    \uC644\uBCBD\uD55C \uC77C\uC2DC \uC815\uC9C0\uB294 \uC544\uB2C8\uC9C0\uB9CC,
    \uC801\uC758 \uACF5\uACA9\uC744 \uD68C\uD53C\uD558\uAC70\uB098 \uB2E4\uC74C \uC804\uB7B5\uC744
    \uAD6C\uC0C1\uD560 \uC218 \uC788\uB294 \uCDA9\uBD84\uD55C \uC5EC\uC720\uAC00
    \uC81C\uACF5\uB429\uB2C8\uB2E4. \uC0C1\uD669\uC5D0 \uB9DE\uB294 \uCD5C\uC801\uC758
    \uD30C\uCE20\uB97C \uC2E0\uC911\uD558\uAC8C \uC120\uD0DD\uD569\uC2DC\uB2E4."
  - "[ \uC870\uC791 \uBC29\uBC95 ]\n- PC\n\uD30C\uCE20 \uAD50\uCCB4 UI \uD65C\uC131\uD654/\uBE44\uD65C\uC131\uD654:
    Tab \uD1A0\uAE00\n\uB9C8\uC6B0\uC2A4\uB97C \uC6C0\uC9C1\uC5EC \uC6D0\uD558\uB294
    \uD30C\uCE20\uC5D0 \uCEE4\uC11C\uB97C \uC62C\uB9AC\uACE0, Tab \uD0A4\uB97C \uB5BC\uAC70\uB098
    \uD074\uB9AD\uD558\uC5EC \uD30C\uCE20\uB97C \uAD50\uCCB4\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n-
    \uBAA8\uBC14\uC77C\n\uD30C\uCE20 \uAD50\uCCB4 UI \uD65C\uC131\uD654/\uBE44\uD65C\uC131\uD654:
    \uC88C\uCE21 \uD30C\uCE20 \uAD50\uCCB4 \uBC84\uD2BC\n\uAD50\uCCB4\uD558\uACE0\uC790
    \uD558\uB294 \uD30C\uCE20 \uC544\uC774\uCF58\uC744 \uD130\uCE58\uD558\uBA74 \uC989\uC2DC
    \uD30C\uCE20\uB97C \uAD50\uCCB4\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  exampleImage: {fileID: 21300000, guid: f03a03381bf7b994aa9a9de6b610cfa7, type: 3}
